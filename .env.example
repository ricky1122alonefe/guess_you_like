# 复制为 .env（已在 .gitignore）
# cp .env.example .env

# PostgreSQL
DATABASE_URL=postgresql://odds:odds@127.0.0.1:5432/odds

# Docker Postgres 镜像（国内网络可改用 DaoCloud）
POSTGRES_IMAGE=postgres:16-alpine
# POSTGRES_IMAGE=docker.m.daocloud.io/library/postgres:16-alpine

# ── AI（也可写在 local_secrets.py）──────────────────
# DEEPSEEK_API_KEY=
# ARK_API_KEY=
# DOUBAO_API_KEY=
# DOUBAO_MODEL=doubao-seed-2-0-lite-260428
# MOONSHOT_API_KEY=
# AI_ENABLE_KIMI=0
# CURSOR_API_KEY=
# CURSOR_MODEL=composer-2.5

# 服务
# PORT=8765
# POLL_DAYS=7

# 可选：API-Football / OpenWeather（不配也能跑：球场用固定目录，天气 Open-Meteo，伤停网页搜索）
