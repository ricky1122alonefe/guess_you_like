{
  "version": 1,
  "primary_id": "deepseek",
  "predict_mode": "multi",
  "providers": [
    {
      "id": "deepseek",
      "label": "DeepSeek 精算师",
      "enabled": true,
      "model": "deepseek-chat",
      "base_url": "https://api.deepseek.com",
